SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=https://www.poskart.my.id
CRON_SECRET=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Required for encrypted private credentials saved from Super Admin
# such as Payment Private and gallery storage providers.
PAYMENT_CREDENTIALS_SECRET=
# Gallery storage provider credentials are configured in Super Admin.
# The Cloudinary values above remain as legacy/fallback credentials.

# Cloudflare R2 builder media storage.
# R2_PUBLIC_BASE_URL should be a public bucket URL or custom domain
# such as https://assets.poskart.my.id, not the S3 API endpoint.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
# Optional override. Defaults to https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=

DUITKU_SANDBOX=false
DUITKU_MERCHANT_CODE=
DUITKU_API_KEY=
DUITKU_PAYMENT_METHOD=SQ

MIDTRANS_SANDBOX=true
MIDTRANS_MERCHANT_ID=
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
MIDTRANS_SERVER_KEY=

# Gallery softfile delivery via Email.
# The backend uses Resend's HTTP API; no npm package is required.
RESEND_API_KEY=
GALLERY_EMAIL_FROM="POSKART <noreply@poskart.my.id>"

# Gallery softfile delivery via WhatsApp Cloud API.
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Optional but recommended for first-contact WhatsApp messages.
# Template body parameters are:
# 1. event/theme name
# 2. gallery download URL
WHATSAPP_GALLERY_TEMPLATE_NAME=
WHATSAPP_GALLERY_TEMPLATE_LANGUAGE=id
